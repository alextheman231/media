{
  "name": "media",
  "version": "1.0.0",
  "description": "Media used in my projects, often created with Manim.",
  "author": "alextheman",
  "license": "ISC",
  "main": "index.js",
  "type": "module",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alextheman231/media.git"
  },
  "sideEffects": false,
  "scripts": {
    "format-package-json": "eslint --fix --suppress-all package.json && rm -f eslint-suppressions.json",
    "format-yml": "prettier --write \"**/*.{yml,yaml}\"",
    "generate": "bash -c 'alex-c-line internal media generate $@' --",
    "lint-exact-versions": "alex-c-line pyproject check --rules prefer-exact-dependency-versions",
    "lint-package-json": "eslint package.json",
    "lint-yml": "prettier --check \"**/*.{yml,yaml}\"",
    "pre-commit": "alex-c-line pre-commit",
    "prepare": "husky",
    "test": "echo \"Error: no test specified\" && exit 1",
    "update-dependencies": "pnpm update --latest && pnpm update"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "devDependencies": {
    "@alextheman/eslint-plugin": "5.15.0",
    "alex-c-line": "2.7.2",
    "eslint": "10.4.0",
    "husky": "9.1.7",
    "prettier": "3.8.3"
  }
}
