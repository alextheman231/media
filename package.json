    "generate": "alex-c-line internal media generate -r 3000,3000 src/commit_to_you",
    "lint-exact-versions": "alex-c-line pyproject check --rules prefer-exact-dependency-versions",
    "lint-package-json": "eslint package.json",
    "lint-yml": "prettier --check \"**/*.{yml,yaml}\"",
    "pre-commit": "alex-c-line pre-commit",
    "prepare": "husky",
    "test": "echo \"Error: no test specified\" && exit 1",
    "update-dependencies": "pnpm update --latest && pnpm update"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "devDependencies": {
    "@alextheman/eslint-plugin": "5.12.0",
    "alex-c-line": "2.7.0",
    "eslint": "10.2.0",
    "husky": "9.1.7",
    "prettier": "3.8.2"
  }
}
